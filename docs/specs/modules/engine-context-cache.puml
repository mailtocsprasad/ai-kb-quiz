@startuml engine-context-cache
skinparam classAttributeIconSize 0

class ContextCache {
  - _path : Path
  - _data : dict[str, str]
  --
  + __init__(cache_path: Path)
  + get(text: str) : str | None
  + set(text: str, context: str) : void
  + save() : void
  - {static} _key(text: str) : str
}

note right of ContextCache
  Content-addressed:
    key = SHA-256(chunk.text)
    value = context string from model
  Same chunk text always maps
    to the same cache key —
    file renames don't miss cache.
  Persists as JSON at _path.
  get()/set() take raw chunk text;
  hashing is internal to _key().
end note

@enduml
