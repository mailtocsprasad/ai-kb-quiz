@startuml engine-manifest
skinparam classAttributeIconSize 0

class Manifest {
  - _path : Path
  - _data : dict[str, dict]
  --
  + __init__(manifest_path: Path)
  + diff(disk_files: list[Path]) : tuple[list, list, list]
  + update(path: Path, chunk_ids: list[str]) : void
  + remove(path: Path) : void
  + get_chunk_ids(path: Path) : list[str]
  + save() : void
  - {static} _key(path: Path) : str
  - _is_changed(path: Path) : bool
}

note right of Manifest
  Persists as JSON at manifest_path
  Keys normalised to forward slashes
  _data schema:
    { "kb/file.md": {
        "mtime": 1713000000.0,
        "chunk_ids": ["kb/file.md::0", ...]
      } }
  diff() returns (new, changed, deleted)
  mtime tolerance: 0.01s
end note

@enduml
