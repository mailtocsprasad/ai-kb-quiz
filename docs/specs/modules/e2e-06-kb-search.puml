@startuml e2e-06-kb-search
skinparam sequenceMessageAlign center
title E2E-06: CLI KB Search

actor User
participant "CLI\nmain.py" as CLI
participant "Retriever" as RET
participant "EmbedFn\n(sentence-transformers)" as EMB
participant "VectorStore\n(ChromaDB)" as VS

User -> CLI : python cli/main.py kb search "kernel callbacks" --top 5

CLI -> RET : search("kernel callbacks", top_k=5, threshold=0.0)

alt index_dir does not exist
  RET --> CLI : raise IndexNotFoundError\n("Run: python cli/main.py kb index")
  CLI --> User : Error: Index not found.\n  Run: python cli/main.py kb index
end

RET -> EMB : encode("kernel callbacks")
EMB --> RET : query_vector[384]

RET -> VS : query(query_vector, top_k=5, threshold=0.0)
VS --> RET : [\n  {chunk, score=0.91, heading="Kernel Callbacks", file="windows-internals.md"},\n  {chunk, score=0.84, heading="PsSetCreateProcessNotifyRoutine", file="edr-sensors.md"},\n  ...\n]

RET -> RET : map to List[Chunk]\nsort by score desc

RET --> CLI : [Chunk(...), Chunk(...), ...]

CLI --> User : [0.9100] Kernel Callbacks: PsSetCreateProcessNotifyRoutine registers...\n[0.8400] PsSetCreateProcessNotifyRoutine: Invoked on every process creation...\n...

@enduml
