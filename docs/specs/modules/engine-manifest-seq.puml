@startuml engine-manifest-seq
skinparam sequenceMessageAlign center

participant Indexer
participant Manifest
participant "VectorStore" as VS

Indexer -> Manifest : diff(kb_dir)
Manifest --> Indexer : FileDiff(new=[f_new], changed=[f_changed], deleted=[f_deleted])

== Handle deleted ==
Indexer -> VS : delete_by_source(str(f_deleted))
note right : ChromaDB where-filter — no chunk\nID tracking needed in Manifest
Indexer -> Manifest : remove(f_deleted)

== Handle changed (re-index) ==
Indexer -> VS : delete_by_source(str(f_changed))
note right : Remove stale vectors before re-indexing
Indexer -> Indexer : _index_file(f_changed)
Indexer -> Manifest : update(f_changed)

== Handle new ==
Indexer -> Indexer : _index_file(f_new)
Indexer -> Manifest : update(f_new)

@enduml
