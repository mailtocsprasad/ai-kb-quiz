@startuml engine-store-seq
skinparam sequenceMessageAlign center

actor Caller
participant "VectorStore" as VS
participant "ChromaDB\nCollection" as COL

== add (batch upsert) ==
Caller -> VS : add(["chunk::0", "chunk::1"], [vec0, vec1],\n        ["doc0", "doc1"],\n        [{source_file, heading}, ...])
VS -> COL : upsert(ids, embeddings, documents, metadatas)

== query ==
Caller -> VS : query(query_vector, n_results=5)
VS -> COL : count()
alt count == 0
  VS --> Caller : []
else count > 0
  VS -> COL : query(query_embeddings=[query_vector],\n             n_results=min(n_results, count),\n             include=[documents, metadatas, distances])
  COL --> VS : ids[], documents[], metadatas[], distances[]
  loop for each result
    VS -> VS : score = 1.0 - distance
  end
  VS --> Caller : list[dict{id, document, metadata, score}]
end

== delete by IDs ==
Caller -> VS : delete(["chunk::0", "chunk::1"])
VS -> COL : delete(ids=["chunk::0", "chunk::1"])

== delete_by_source ==
Caller -> VS : delete_by_source("/kb/topic_a.md")
VS -> COL : count()
VS -> COL : get(where={"source_file": {"$eq": "/kb/topic_a.md"}})
COL --> VS : {ids: ["chunk::0", "chunk::1"], ...}
VS -> COL : delete(ids=["chunk::0", "chunk::1"])

@enduml
